# PostgreSQL connection string
# For Railway: automatically set as DATABASE_URL when you add a PostgreSQL plugin
# For local dev: use a local PostgreSQL instance or Railway's dev DB
DATABASE_URL="postgresql://user:password@localhost:5432/qms?schema=public"

# NextAuth secret - generate with: openssl rand -base64 32
AUTH_SECRET="replace-this-with-a-real-secret-in-production"

# Optional: set to your production domain
# NEXTAUTH_URL="https://your-app.railway.app"

# ---- MS365 AI Connector ----

# Azure AD App Registration (from portal.azure.com > App registrations)
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# Encryption key for MS365 token storage - generate with: openssl rand -hex 32
M365_ENCRYPTION_KEY=""

# Anthropic Claude API key (from console.anthropic.com)
ANTHROPIC_API_KEY=""

# Secret to protect the cron polling endpoint - generate with: openssl rand -hex 24
CRON_SECRET=""

# App URL (used for OAuth callback redirect)
NEXT_PUBLIC_APP_URL="https://qms-mx-system-production.up.railway.app"
