# PostgreSQL connection string
# For Railway: automatically set as DATABASE_URL when you add a PostgreSQL plugin
# For local dev: use a local PostgreSQL instance or Railway's dev DB
DATABASE_URL="postgresql://user:password@localhost:5432/qms?schema=public"

# NextAuth secret - generate with: openssl rand -base64 32
AUTH_SECRET="replace-this-with-a-real-secret-in-production"

# Optional: set to your production domain
# NEXTAUTH_URL="https://your-app.railway.app"
