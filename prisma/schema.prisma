generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  passwordHash   String
  role           String    @default("operator") // "admin" | "operator"
  phone          String?
  carrier        String?   // SMS gateway domain: "vtext.com", "tmomail.net", etc.
  notifyEmail    Boolean   @default(true)
  notifySMS      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  maintenanceLogs MaintenanceLog[]
  assignedOrders  WorkOrder[]      @relation("AssignedTo")
  createdOrders   WorkOrder[]      @relation("CreatedBy")
  m365Connections M365Connection[]
  reviewedSuggestions AISuggestion[] @relation("SuggestionReviewer")
  notifications   Notification[]
  createdProjects Project[]        @relation("ProjectCreator")
  scannedMessages ProcessedMessage[] @relation("ScannedMessages")
  submittedNCRs      NonConformance[]   @relation("SubmittedNCRs")
  approvedNCRs       NonConformance[]   @relation("ApprovedNCRs")
  originatedCAPAs    CAPA[]             @relation("OriginatedCAPAs")
  assignedCAPAs      CAPA[]             @relation("AssignedCAPAs")
  verifiedCAPAs      CAPA[]             @relation("VerifiedCAPAs")
  submittedComplaints CustomerComplaint[] @relation("SubmittedComplaints")
  approvedWorkOrders WorkOrder[]        @relation("ApprovedWorkOrders")
}

model Equipment {
  id                String    @id @default(cuid())
  name              String
  type              String
  location          String
  serialNumber      String    @unique
  status            String    @default("operational") // "operational" | "needs_service" | "down"
  notes             String?
  criticality       String?   // "A" | "B" | "C" — from PM system
  groupName         String?   // Functional group: "Compression Molding", "Extrusion", etc.
  parentId          String?   // Parent equipment ID for sub-components (e.g., pump → press)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  parent          Equipment?  @relation("EquipmentHierarchy", fields: [parentId], references: [id])
  children        Equipment[] @relation("EquipmentHierarchy")
  schedules       MaintenanceSchedule[]
  maintenanceLogs MaintenanceLog[]
  workOrders      WorkOrder[]

  @@index([status])
  @@index([parentId])
}

model MaintenanceSchedule {
  id                String   @id @default(cuid())
  equipmentId       String
  title             String
  description       String?
  frequency         String   // "daily" | "weekly" | "monthly" | "quarterly" | "annual"
  lastDone          DateTime?
  nextDue           DateTime
  sourceWorkOrderId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  equipment       Equipment  @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  sourceWorkOrder WorkOrder? @relation("SourceWorkOrder", fields: [sourceWorkOrderId], references: [id])

  @@index([nextDue])
}

model MaintenanceLog {
  id          String   @id @default(cuid())
  equipmentId String
  userId      String
  description String
  partsUsed   String?
  performedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])
}

model WorkOrder {
  id           String    @id @default(cuid())
  equipmentId  String
  assignedToId String?
  createdById  String
  title        String
  description  String
  priority     String    @default("medium") // "low" | "medium" | "high" | "critical"
  status       String    @default("open")   // "open" | "in_progress" | "completed" | "cancelled"
  dueDate      DateTime?
  completedAt  DateTime?
  workOrderType   String    @default("corrective") // "routine" | "preventive" | "corrective" | "emergency"
  requirements    String?   // F-16: end goal, specific requirements, detailed expectations
  managerNotes    String?   // F-16: supervisor/manager notes
  estimatedBudget String?   // F-16: estimated budget
  estimatedLeadTime String? // F-16: estimated lead time
  plannedStartDate DateTime? // F-16: planned start date
  approvedById    String?
  approvedAt      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  equipment  Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy  User      @relation("CreatedBy", fields: [createdById], references: [id])
  approvedBy User?     @relation("ApprovedWorkOrders", fields: [approvedById], references: [id])
  createdSchedules MaintenanceSchedule[] @relation("SourceWorkOrder")

  @@index([status])
  @@index([priority])
}

model M365Connection {
  id              String    @id @default(cuid())
  tenantId        String
  clientId        String
  accessTokenEnc  String
  refreshTokenEnc String
  tokenExpiresAt  DateTime
  scopes          String    // comma-separated scopes
  connectedBy     String
  isActive        Boolean   @default(true)
  deltaLink       String?   // delta link for incremental mail polling
  lastPolledAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  connectedByUser User @relation(fields: [connectedBy], references: [id])

  @@index([connectedBy])
}

model M365MonitorConfig {
  id           String    @id @default(cuid())
  sourceType   String    // "mailbox" | "teams_channel"
  sourceId     String    // email address or "teamId/channelId"
  displayName  String
  isActive     Boolean   @default(true)
  lastPolledAt DateTime?
  deltaLink    String?   // MS Graph delta link for incremental polling
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ProcessedMessage {
  id              String   @id @default(cuid())
  externalId      String   @unique // MS Graph message ID
  sourceType      String   // "email" | "teams" | "sharepoint"
  sourceId        String
  scannedByUserId String?  // which user triggered this scan
  subject         String?
  senderName      String?
  senderEmail     String?
  bodyPreview     String   // first ~500 chars
  receivedAt      DateTime
  processedAt     DateTime @default(now())
  aiAnalysis      String?  // Full JSON from Claude
  actionTaken     String   // "work_order" | "maintenance_log" | "status_update" | "ignored" | "pre_filtered" | "flag_for_review"
  confidence      Float?

  scannedByUser User? @relation("ScannedMessages", fields: [scannedByUserId], references: [id])
  suggestions   AISuggestion[]

  @@index([scannedByUserId])
}

model AISuggestion {
  id                 String    @id @default(cuid())
  processedMessageId String
  suggestionType     String    // "create_work_order" | "create_maintenance_log" | "update_equipment_status" | "flag_for_review" | "create_project" | "create_auxiliary_equipment" | "progress_existing"
  status             String    @default("pending") // "pending" | "approved" | "rejected" | "auto_applied"
  payload            String    // JSON with proposed action details
  createdRecordType  String?   // "WorkOrder" | "MaintenanceLog" | "Equipment"
  createdRecordId    String?
  sharePointDocId    String?   // optional link to SharePointDocument
  reviewedBy         String?
  reviewedAt         DateTime?
  reviewNote         String?
  createdAt          DateTime  @default(now())

  processedMessage ProcessedMessage @relation(fields: [processedMessageId], references: [id], onDelete: Cascade)
  reviewer         User?            @relation("SuggestionReviewer", fields: [reviewedBy], references: [id])

  @@index([status])
}

model M365SharePointSite {
  id            String    @id @default(cuid())
  siteId        String    @unique
  siteName      String
  siteUrl       String
  isActive      Boolean   @default(true)
  lastScannedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SharePointDocument {
  id           String   @id @default(cuid())
  externalId   String   @unique
  siteId       String
  name         String
  webUrl       String
  contentType  String?
  lastModified DateTime
  aiAnalysis   String?
  actionTaken  String   @default("none")
  processedAt  DateTime @default(now())
}

model Project {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("planning") // "planning" | "in_progress" | "completed" | "on_hold"
  priority    String    @default("medium")   // "low" | "medium" | "high" | "critical"
  budget      String?
  dueDate     DateTime?
  completedAt DateTime?
  phase              String    @default("concept") // "concept" | "design" | "production_release" | "complete"
  projectJustification String? // F-17 Phase 1
  designObjectives   String?   // F-17 Phase 1
  designRequirements String?   // F-17 Phase 1
  potentialVendors   String?   // F-17 Phase 1
  salesMarketingActions String? // F-17 Phase 2
  engineeringActions String?   // F-17 Phase 2 (JSON array of {task, who, when})
  releaseChecklist   String?   // F-17 Phase 3 (JSON object of checklist items)
  actualBudget       String?   // F-17 Phase 3
  plannedSchedule    String?   // F-17 Phase 3
  actualSchedule     String?   // F-17 Phase 3
  isComplete         String?   // "yes" | "no" | "contingent"
  contingentDetails  String?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy User @relation("ProjectCreator", fields: [createdById], references: [id])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "work_order_assigned" | "work_order_created" | "status_changed" | "equipment_down" | "equipment_status" | "project_created" | "maintenance_logged" | "maintenance_due"
  title       String
  message     String
  read        Boolean  @default(false)
  urgency     String   @default("digest")  // "immediate" | "digest"
  emailSent   Boolean  @default(false)
  relatedType String?  // "WorkOrder" | "Equipment" | "AISuggestion" | "MaintenanceSchedule" | "Project" | "MaintenanceLog"
  relatedId   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([urgency, emailSent])
}

model NonConformance {
  id                  String    @id @default(cuid())
  ncrNumber           String    @unique // Auto-generated: NCR-YYYY-001
  submittedById       String
  date                DateTime  @default(now())
  partNumber          String?   // Part # or Process Description
  drawingNumber       String?
  drawingRevision     String?
  quantityAffected    String?
  vendor              String?
  otherInfo           String?
  ncrType             String    // "aesthetic" | "dimensional" | "function" | "quality" | "safety" | "compliance"
  requirementDescription String // Describe the requirement or specification
  nonConformanceDescription String // Describe the Non-Conformance
  disposition         String?   // "rework" | "return_to_vendor" | "scrap" | "use_as_is"
  immediateAction     String?
  approvedById        String?
  approvedAt          DateTime?
  ncrTagNumber        String?
  plantLocation       String?
  status              String    @default("open") // "open" | "under_review" | "dispositioned" | "closed"
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  submittedBy  User  @relation("SubmittedNCRs", fields: [submittedById], references: [id])
  approvedBy   User? @relation("ApprovedNCRs", fields: [approvedById], references: [id])
  capas        CAPA[] @relation("NCRToCapa")
  linkedComplaints CustomerComplaint[] @relation("ComplaintNCR")

  @@index([status])
  @@index([ncrType])
}

model CAPA {
  id                    String    @id @default(cuid())
  capaNumber            String    @unique // Auto-generated: CAPA-YYYY-001
  originatorId          String
  department            String?
  referenceNcrId        String?   // Link to NonConformance
  targetCloseDate       DateTime?
  assignedToId          String?
  source                String    // "internal_audit" | "customer_complaint" | "supplier_issue" | "process_failure" | "product_defect" | "management_review" | "regulatory_finding" | "other"
  sourceOther           String?
  severityLevel         String    // "low" | "medium" | "high" | "critical"
  // Section 2 - Problem Description
  nonconformanceDescription String // What, Where, When, Extent
  productProcessAffected String?
  quantityScopeAffected  String?
  containmentActions     String?
  // Section 3 - Root Cause Analysis
  rcaMethod             String?   // "5_whys" | "fishbone" | "8d" | "fault_tree" | "pareto" | "fmea" | "other"
  rcaMethodOther        String?
  whyMan                String?   // Human factors
  whyMachine            String?   // Equipment
  whyMethod             String?   // Process
  whyMaterial           String?
  rootCauseStatement    String?
  // Section 4 - Corrective Actions stored in CAPAAction model
  // Section 5 - Effectiveness Verification
  verificationMethod    String?
  verifiedById          String?
  verificationDate      DateTime?
  effectivenessOutcome  String?   // "effective" | "partially_effective" | "ineffective"
  objectiveEvidence     String?
  lessonsLearned        String?
  preventiveActions     String?
  // Section 6 - Approvals & Final
  finalDisposition      String?   // "closed_effective" | "closed_partial_monitor" | "reopened" | "escalated"
  status                String    @default("open") // "open" | "in_progress" | "pending_verification" | "closed"
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  originator    User            @relation("OriginatedCAPAs", fields: [originatorId], references: [id])
  assignedTo    User?           @relation("AssignedCAPAs", fields: [assignedToId], references: [id])
  verifiedBy    User?           @relation("VerifiedCAPAs", fields: [verifiedById], references: [id])
  referenceNcr  NonConformance? @relation("NCRToCapa", fields: [referenceNcrId], references: [id])
  actions       CAPAAction[]
  linkedComplaints CustomerComplaint[] @relation("ComplaintCAPA")

  @@index([status])
  @@index([severityLevel])
}

model CAPAAction {
  id              String    @id @default(cuid())
  capaId          String
  actionNumber    Int
  description     String
  responsibleParty String?
  dueDate         DateTime?
  status          String    @default("planned") // "planned" | "in_progress" | "complete" | "verified"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  capa CAPA @relation(fields: [capaId], references: [id], onDelete: Cascade)

  @@index([capaId])
}

model CustomerComplaint {
  id                  String    @id @default(cuid())
  complaintNumber     String    @unique // Auto-generated: CC-YYYY-001
  submittedById       String
  date                DateTime  @default(now())
  // Customer info
  customerName        String
  customerAddress     String?
  customerContact     String?
  contactPhone        String?
  contactEmail        String?
  // Order info
  partNumber          String?
  salesOrderNumber    String?
  invoiced            String?   // "yes" | "no" | "partial"
  invoiceNumber       String?
  invoiceValue        String?
  drawingNumber       String?
  drawingRevision     String?
  quantityAffected    String?
  otherInfo           String?
  // Complaint details
  complaintType       String    // "aesthetic" | "dimensional" | "function" | "quality" | "safety" | "compliance" | "packaging" | "shipping_damage" | "other"
  complaintDescription String
  // Management disposition
  disposition         String?   // "return_rework" | "return_credit" | "return_refund" | "replace_no_charge" | "other"
  rmaNumber           String?
  customerFacingAction String?
  internalAction      String?
  ncrRequired         Boolean   @default(false)
  capaRequired        Boolean   @default(false)
  affectsOtherOrders  Boolean   @default(false)
  rootCauseRequired   Boolean   @default(false)
  // Linked records
  linkedNcrId         String?
  linkedCapaId        String?
  status              String    @default("open") // "open" | "investigating" | "dispositioned" | "closed"
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  submittedBy  User            @relation("SubmittedComplaints", fields: [submittedById], references: [id])
  linkedNcr    NonConformance? @relation("ComplaintNCR", fields: [linkedNcrId], references: [id])
  linkedCapa   CAPA?           @relation("ComplaintCAPA", fields: [linkedCapaId], references: [id])

  @@index([status])
  @@index([complaintType])
}
