generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  passwordHash   String
  role           String    @default("operator") // "admin" | "operator"
  phone          String?
  carrier        String?   // SMS gateway domain: "vtext.com", "tmomail.net", etc.
  notifyEmail    Boolean   @default(true)
  notifySMS      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  maintenanceLogs MaintenanceLog[]
  assignedOrders  WorkOrder[]      @relation("AssignedTo")
  createdOrders   WorkOrder[]      @relation("CreatedBy")
  m365Connections M365Connection[]
  reviewedSuggestions AISuggestion[] @relation("SuggestionReviewer")
  notifications   Notification[]
  createdProjects Project[]        @relation("ProjectCreator")
  scannedMessages ProcessedMessage[] @relation("ScannedMessages")
}

model Equipment {
  id           String    @id @default(cuid())
  name         String
  type         String
  location     String
  serialNumber String    @unique
  status       String    @default("operational") // "operational" | "needs_service" | "down"
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  schedules       MaintenanceSchedule[]
  maintenanceLogs MaintenanceLog[]
  workOrders      WorkOrder[]

  @@index([status])
}

model MaintenanceSchedule {
  id                String   @id @default(cuid())
  equipmentId       String
  title             String
  description       String?
  frequency         String   // "daily" | "weekly" | "monthly" | "quarterly" | "annual"
  lastDone          DateTime?
  nextDue           DateTime
  sourceWorkOrderId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  equipment       Equipment  @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  sourceWorkOrder WorkOrder? @relation("SourceWorkOrder", fields: [sourceWorkOrderId], references: [id])

  @@index([nextDue])
}

model MaintenanceLog {
  id          String   @id @default(cuid())
  equipmentId String
  userId      String
  description String
  partsUsed   String?
  performedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])
}

model WorkOrder {
  id           String    @id @default(cuid())
  equipmentId  String
  assignedToId String?
  createdById  String
  title        String
  description  String
  priority     String    @default("medium") // "low" | "medium" | "high" | "critical"
  status       String    @default("open")   // "open" | "in_progress" | "completed" | "cancelled"
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  equipment  Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy  User      @relation("CreatedBy", fields: [createdById], references: [id])
  createdSchedules MaintenanceSchedule[] @relation("SourceWorkOrder")

  @@index([status])
  @@index([priority])
}

model M365Connection {
  id              String    @id @default(cuid())
  tenantId        String
  clientId        String
  accessTokenEnc  String
  refreshTokenEnc String
  tokenExpiresAt  DateTime
  scopes          String    // comma-separated scopes
  connectedBy     String
  isActive        Boolean   @default(true)
  deltaLink       String?   // delta link for incremental mail polling
  lastPolledAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  connectedByUser User @relation(fields: [connectedBy], references: [id])

  @@index([connectedBy])
}

model M365MonitorConfig {
  id           String    @id @default(cuid())
  sourceType   String    // "mailbox" | "teams_channel"
  sourceId     String    // email address or "teamId/channelId"
  displayName  String
  isActive     Boolean   @default(true)
  lastPolledAt DateTime?
  deltaLink    String?   // MS Graph delta link for incremental polling
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ProcessedMessage {
  id              String   @id @default(cuid())
  externalId      String   @unique // MS Graph message ID
  sourceType      String   // "email" | "teams" | "sharepoint"
  sourceId        String
  scannedByUserId String?  // which user triggered this scan
  subject         String?
  senderName      String?
  senderEmail     String?
  bodyPreview     String   // first ~500 chars
  receivedAt      DateTime
  processedAt     DateTime @default(now())
  aiAnalysis      String?  // Full JSON from Claude
  actionTaken     String   // "work_order" | "maintenance_log" | "status_update" | "ignored" | "pre_filtered" | "flag_for_review"
  confidence      Float?

  scannedByUser User? @relation("ScannedMessages", fields: [scannedByUserId], references: [id])
  suggestions   AISuggestion[]

  @@index([scannedByUserId])
}

model AISuggestion {
  id                 String    @id @default(cuid())
  processedMessageId String
  suggestionType     String    // "create_work_order" | "create_maintenance_log" | "update_equipment_status" | "flag_for_review"
  status             String    @default("pending") // "pending" | "approved" | "rejected" | "auto_applied"
  payload            String    // JSON with proposed action details
  createdRecordType  String?   // "WorkOrder" | "MaintenanceLog" | "Equipment"
  createdRecordId    String?
  sharePointDocId    String?   // optional link to SharePointDocument
  reviewedBy         String?
  reviewedAt         DateTime?
  reviewNote         String?
  createdAt          DateTime  @default(now())

  processedMessage ProcessedMessage @relation(fields: [processedMessageId], references: [id], onDelete: Cascade)
  reviewer         User?            @relation("SuggestionReviewer", fields: [reviewedBy], references: [id])

  @@index([status])
}

model M365SharePointSite {
  id            String    @id @default(cuid())
  siteId        String    @unique
  siteName      String
  siteUrl       String
  isActive      Boolean   @default(true)
  lastScannedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SharePointDocument {
  id           String   @id @default(cuid())
  externalId   String   @unique
  siteId       String
  name         String
  webUrl       String
  contentType  String?
  lastModified DateTime
  aiAnalysis   String?
  actionTaken  String   @default("none")
  processedAt  DateTime @default(now())
}

model Project {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("planning") // "planning" | "in_progress" | "completed" | "on_hold"
  priority    String    @default("medium")   // "low" | "medium" | "high" | "critical"
  budget      String?
  dueDate     DateTime?
  completedAt DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy User @relation("ProjectCreator", fields: [createdById], references: [id])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "work_order_assigned" | "status_changed" | "suggestion_review" | "maintenance_due"
  title       String
  message     String
  read        Boolean  @default(false)
  relatedType String?  // "WorkOrder" | "Equipment" | "AISuggestion" | "MaintenanceSchedule" | "Project"
  relatedId   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
